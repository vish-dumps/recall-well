{
  "manifest_version": 3,
  "name": "Recall Capture",
  "description": "Capture coding problem details and create notes in Recall Well.",
  "version": "1.1.0",
  "action": {
    "default_title": "Recall Capture",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "http://localhost:4000/*",
    "http://127.0.0.1:4000/*",
    "https://leetcode.com/*",
    "https://*.leetcode.com/*",
    "https://codeforces.com/*",
    "https://*.codeforces.com/*",
    "https://geeksforgeeks.org/*",
    "https://*.geeksforgeeks.org/*",
    "https://codingninjas.com/*",
    "https://*.codingninjas.com/*",
    "https://naukri.com/*",
    "https://*.naukri.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://*.leetcode.com/*",
        "https://codeforces.com/*",
        "https://*.codeforces.com/*",
        "https://geeksforgeeks.org/*",
        "https://*.geeksforgeeks.org/*",
        "https://codingninjas.com/*",
        "https://*.codingninjas.com/*",
        "https://naukri.com/*",
        "https://*.naukri.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
